<mujoco model="ur5e vla scene">
  <include file="ur5e.xml"/>

  <statistic center="0.3 0 0.4" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Colored reach targets for language-conditioned tasks -->
    <body name="target_red" pos="0.4 -0.2 0.5">
      <geom type="sphere" size="0.03" rgba="1 0 0 0.9" contype="0" conaffinity="0"/>
    </body>
    <body name="target_green" pos="0.3 0.2 0.4">
      <geom type="sphere" size="0.03" rgba="0 1 0 0.9" contype="0" conaffinity="0"/>
    </body>
    <body name="target_blue" pos="0.2 0.0 0.65">
      <geom type="sphere" size="0.03" rgba="0 0 1 0.9" contype="0" conaffinity="0"/>
    </body>

    <!-- Workspace camera for visual observations -->
    <camera name="workspace_cam" pos="1.0 -0.8 0.9" xyaxes="0.707 0.707 0 -0.354 0.354 0.866" fovy="55"/>
  </worldbody>
</mujoco>
